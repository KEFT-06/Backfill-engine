# Copy to .env and adjust. All settings are read by src/backfill/config.py.
# Prefix is BACKFILL_ (see Settings.model_config).

BACKFILL_PG_DSN=postgresql://backfill:backfill@localhost:5432/backfill

BACKFILL_S3_ENDPOINT=localhost:9000
BACKFILL_S3_ACCESS_KEY=minioadmin
BACKFILL_S3_SECRET_KEY=minioadmin
BACKFILL_S3_BUCKET=backfill
BACKFILL_S3_SECURE=false

BACKFILL_MAX_CONCURRENCY=4
BACKFILL_MAX_ATTEMPTS=5

BACKFILL_GHARCHIVE_BASE_URL=https://data.gharchive.org
